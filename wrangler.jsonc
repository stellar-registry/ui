{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "registry-ui",
	"main": "./workers/app.ts",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true,
	},

	// Default vars for local development (wrangler dev reads .dev.vars)
	"vars": {
		"REGISTRY_API_URL": "https://registry-indexer.fly.dev/v1",
		"REGISTRY_NETWORK": "testnet",
	},
}
